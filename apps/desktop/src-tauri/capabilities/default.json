{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "enables the default permissions",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"dialog:default",
		"dialog:allow-save",
		"dialog:allow-open",
		{
			"identifier": "fs:allow-write-file",
			"allow": [
				{ "path": "**" },
				{ "path": "$HOME/**" },
				{ "path": "$DOCUMENT/**" },
				{ "path": "$DOWNLOAD/**" },
				{ "path": "$DESKTOP/**" }
			]
		}
	]
}
