{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "GlyphX",
	"version": "0.1.0",
	"identifier": "com.nexonauts.glyphx",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "pnpm run ui:dev",
		"beforeBuildCommand": "pnpm run ui:build"
	},
	"app": {
		"windows": [
			{
				"title": "GlyphX",
				"width": 1280,
				"height": 832,
				"minWidth": 880,
				"minHeight": 600,
				"center": true,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"externalBin": [
			"binaries/tectonic"
		],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"fileAssociations": [
			{
				"ext": [
					"tex"
				],
				"name": "LaTeX Document",
				"description": "LaTeX source document",
				"role": "Editor"
			},
			{
				"ext": [
					"glyphx"
				],
				"name": "GlyphX Project",
				"description": "GlyphX LaTeX project",
				"role": "Editor"
			}
		],
		"windows": {
			"digestAlgorithm": "sha256",
			"timestampUrl": "http://timestamp.digicert.com"
		},
		"macOS": {
			"minimumSystemVersion": "13.0"
		},
		"linux": {
			"appimage": {}
		},
		"createUpdaterArtifacts": true,
		"android": {
			"debugApplicationIdSuffix": ".debug"
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBMDUyMzE0NDAwMUVGN0QKUldSOTd3RkFGQ01GaXEydXZqMmpTTHYzV1Nnc2E4ei9PZXdUN3BRK1VVRlZHRWNqQW1pWHJVd2sK",
			"endpoints": [
				"https://github.com/kanakkholwal/glyph/releases/latest/download/latest.json"
			],
			"dialog": false
		}
	}
}