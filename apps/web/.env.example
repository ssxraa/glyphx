# Glyph web — environment variables (copy to .env, or set in the deploy host).

# TeX Live on-demand server the in-browser engine fetches packages from.
# Optional. When set, it's tried FIRST and the app falls back to the public
# TeXlyre server (https://texlive.texlyre.org/) if yours is unreachable.
# Point this at your own (free) Cloudflare-Tunnel server — see
# apps/web/docs/self-host-texlive.md.
PUBLIC_TEXLIVE_ENDPOINT=https://texlive.glyphx.nexonauts.com/
