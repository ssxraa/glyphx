{
  "name": "glyph",
  "version": "0.0.0",
  "private": true,
  "description": "Glyph — local-first, privacy-first LaTeX editor. Desktop (Tauri) + web, sharing one UI.",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@glyph/web",
    "dev:desktop": "turbo run dev --filter=@glyph/desktop",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@glyph/web",
    "build:desktop": "turbo run build --filter=@glyph/desktop",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
