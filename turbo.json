{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".svelte-kit/**", "build/**", "dist/**", ".vercel/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "lint:rust": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {}
  }
}
